###############################################################################
### Copy this file to .env and fill in your values                          ###
### Never commit .env — it is gitignored                                    ###
###############################################################################

# Ethereum private key for CRE workflow signing
CRE_ETH_PRIVATE_KEY=

# Default settings target (staging-settings | production-settings)
CRE_TARGET=staging-settings

# Weather API keys (used by agent-main.ts)
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=
# WeatherAPI: https://www.weatherapi.com/
WEATHERAPI_KEY=
